<Window
    x:Class="Vinoteca.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Background="Transparent" Canvas.ZIndex="1">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="12">
				<Image Source="Assets/StoreLogo.png" Width="22" Height="22"/>
				<TextBlock Text="Vinoteca DODO" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}" VerticalAlignment="Center"/>
			</StackPanel>
		</Grid>

		<Frame x:Name="RootFrame" Grid.Row="1"/>
	</Grid>
</Window>
