<Page
    x:Class="Vinoteca.Views.VentasAdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
	</Page.Resources>

	<Grid Padding="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" Text="Carrito de Ventas" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>

		<ListView x:Name="lvCarrito" Grid.Row="1" Margin="0,0,0,20" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="models:CarritoItem">
					<Grid Padding="10">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0">
							<TextBlock Text="{x:Bind Producto.Nombre}" FontWeight="Bold" FontSize="16"/>
							<TextBlock Text="{x:Bind Producto.Marca}" FontSize="12" Foreground="Gray"/>
						</StackPanel>

						<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
							<TextBlock Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Cant: {0}'}" HorizontalAlignment="Center"/>
						</StackPanel>

						<TextBlock Grid.Column="2" 
                                   Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" 
                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16"/>
					</Grid>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

		<StackPanel Grid.Row="2" HorizontalAlignment="Right" Spacing="15">
			<StackPanel Orientation="Horizontal" Spacing="10">
				<TextBlock Text="Total a Pagar:" FontSize="20" VerticalAlignment="Center"/>
				<TextBlock x:Name="txtTotalCarrito" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
				<Button Content="Vaciar Carrito" Click="btnVaciar_Click"/>
				<Button Content="Finalizar Venta" Click="btnFinalizarVenta_Click" Style="{ThemeResource AccentButtonStyle}" Padding="30,10"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Page>