<Page
    x:Class="Vinoteca.Views.VentasAdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{StaticResource WineBackgroundBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
	</Page.Resources>

	<Grid Background="{StaticResource WineBackgroundBrush}" Padding="12">
		<Border Style="{StaticResource WineCardStyle}" Padding="24">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,20">
					<TextBlock x:Name="txtTitulo" Text="Panel de venta" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock x:Name="txtSubtitulo" Text="0 articulo(s) listos para procesar" Foreground="{StaticResource WineMutedBrush}"/>
					<TextBlock x:Name="txtEstado" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
				</StackPanel>

				<Grid Grid.Row="1">
					<ListView x:Name="lvCarrito" Margin="0,0,0,20" SelectionMode="None" Background="Transparent">
						<ListView.ItemTemplate>
							<DataTemplate x:DataType="models:CarritoItem">
								<Border Margin="0,0,0,10" Padding="16" CornerRadius="16" Background="#FFF8F2" BorderThickness="1" BorderBrush="{StaticResource WineBorderBrush}">
									<Grid ColumnSpacing="12">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>

										<StackPanel Grid.Column="0">
											<TextBlock Text="{x:Bind Producto.Nombre}" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource WineTextBrush}"/>
											<TextBlock Text="{x:Bind Producto.Marca}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
										</StackPanel>

										<TextBlock Grid.Column="1" Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Cant: {0}'}" Margin="20,0" VerticalAlignment="Center" Foreground="{StaticResource WineMutedBrush}"/>

										<TextBlock Grid.Column="2" Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource WineHeroBrush}"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>

					<TextBlock x:Name="txtVacio" Text="No hay productos en esta venta" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}"/>
				</Grid>

				<StackPanel Grid.Row="2" Spacing="14">
					<Border Style="{StaticResource WineFilterPillStyle}" Padding="14">
						<Grid ColumnSpacing="12" RowSpacing="8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="1.1*"/>
								<ColumnDefinition Width="1*"/>
								<ColumnDefinition Width="1.2*"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Text="Metodo de pago" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="1" Text="Monto recibido" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
							<TextBlock Grid.Column="2" Text="Referencia" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>

							<ComboBox x:Name="cmbMetodoPago" Grid.Row="1" Style="{StaticResource WineComboBoxStyle}" SelectionChanged="cmbMetodoPago_SelectionChanged">
								<ComboBoxItem Content="Efectivo"/>
								<ComboBoxItem Content="Tarjeta"/>
								<ComboBoxItem Content="Transferencia"/>
							</ComboBox>
							<TextBox x:Name="txtMontoRecibido" Grid.Row="1" Grid.Column="1" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="0.00" TextChanged="txtPago_TextChanged"/>
							<TextBox x:Name="txtReferenciaPago" Grid.Row="1" Grid.Column="2" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Autorizacion o folio" MaxLength="40" TextChanged="txtPago_TextChanged"/>
						</Grid>
					</Border>

					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel>
							<TextBlock x:Name="txtPagoAyuda" Text="Ingresa el efectivo recibido para calcular el cambio" Foreground="{StaticResource WineMutedBrush}"/>
							<TextBlock x:Name="txtCambio" Text="Cambio: $0.00" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						</StackPanel>

						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
							<TextBlock Text="Total:" FontSize="20" VerticalAlignment="Center" Foreground="{StaticResource WineTextBrush}"/>
							<TextBlock x:Name="txtTotalCarrito" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WineHeroBrush}"/>
						</StackPanel>
					</Grid>

					<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
						<Button Content="Vaciar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnVaciar_Click"/>
						<Button Content="Cobrar y emitir ticket" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnFinalizarVenta_Click"/>
					</StackPanel>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Page>
