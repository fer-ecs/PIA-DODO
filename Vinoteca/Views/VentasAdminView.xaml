<Page
    x:Class="Vinoteca.Views.VentasAdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
	</Page.Resources>

	<Grid Padding="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0,0,0,20">
			<TextBlock x:Name="txtTitulo" Text="Panel de venta" Style="{ThemeResource TitleTextBlockStyle}"/>
			<TextBlock x:Name="txtSubtitulo" Text="0 articulo(s) listos para procesar" Opacity="0.75"/>
			<TextBlock x:Name="txtEstado" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
		</StackPanel>

		<Grid Grid.Row="1">
			<ListView x:Name="lvCarrito" Margin="0,0,0,20" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" SelectionMode="None">
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="models:CarritoItem">
						<Grid Padding="10">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0">
								<TextBlock Text="{x:Bind Producto.Nombre}" FontWeight="Bold" FontSize="16"/>
								<TextBlock Text="{x:Bind Producto.Marca}" FontSize="12" Foreground="Gray"/>
							</StackPanel>

							<TextBlock Grid.Column="1" Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Cant: {0}'}" Margin="20,0" VerticalAlignment="Center"/>

							<TextBlock Grid.Column="2" Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16"/>
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>

			<TextBlock x:Name="txtVacio" Text="No hay productos en esta venta" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}"/>
		</Grid>

		<StackPanel Grid.Row="2" HorizontalAlignment="Right" Spacing="15">
			<StackPanel Orientation="Horizontal" Spacing="10">
				<TextBlock Text="Total:" FontSize="20" VerticalAlignment="Center"/>
				<TextBlock x:Name="txtTotalCarrito" Text="$0.00" FontSize="32" FontWeight="Bold" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
				<Button Content="Vaciar" Click="btnVaciar_Click"/>
				<Button Content="Confirmar" Click="btnFinalizarVenta_Click" Style="{ThemeResource AccentButtonStyle}" Padding="30,10"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Page>
