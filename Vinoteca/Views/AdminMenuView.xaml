<Page
    x:Class="Vinoteca.Views.AdminMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="260"/>
			<!-- Sidebar -->
			<ColumnDefinition Width="*"/>
			<!-- Contenido -->
		</Grid.ColumnDefinitions>

		<!-- SIDEBAR -->
		<Border Grid.Column="0" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0,0,1,0">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<!-- Logo -->
					<RowDefinition Height="*"/>
					<!-- Navegación -->
					<RowDefinition Height="Auto"/>
					<!-- Admin info -->
				</Grid.RowDefinitions>

				<!-- Logo -->
				<StackPanel Grid.Row="0" Padding="24,32,24,24" Spacing="4">
					<TextBlock Text="Vinoteca" Style="{ThemeResource TitleTextBlockStyle}"/>
					<TextBlock Text="Administración" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
				</StackPanel>

				<!-- Navegación -->
				<StackPanel Grid.Row="1" Padding="12,0" Spacing="4">
					<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="8" Padding="12,10" Click="btnNavInventario_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Library"/>
							<TextBlock Text="Inventario" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>

					<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="8" Padding="12,10" Click="btnNavUsuarios_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="People"/>
							<TextBlock Text="Usuarios" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>

					<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="8" Padding="12,10" Click="btnNavVentas_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Tag"/>
							<TextBlock Text="Ventas" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>

					<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" CornerRadius="8" Padding="12,10" Click="btnNavReportes_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Document"/>
							<TextBlock Text="Reportes" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<!-- Footer (Admin info + Logout) -->
				<Border Grid.Row="2" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="8"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<StackPanel Grid.Row="0" Spacing="2">
							<TextBlock x:Name="txtNombreAdminActivo" Text="Admin" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
							<TextBlock x:Name="txtCorreoAdminActivo" Text="admin@vinoteca.com" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
						</StackPanel>

						<Button Grid.Row="2" x:Name="btnCerrarSesionAdmin" Content="Cerrar Sesión" HorizontalAlignment="Stretch" CornerRadius="6" Click="btnCerrarSesionAdmin_Click"/>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<!-- CONTENIDO CENTRAL -->
		<Frame Grid.Column="1" x:Name="AdminContentFrame"/>
	</Grid>
</Page>