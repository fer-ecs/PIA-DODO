<Page
    x:Class="Vinoteca.Views.AdminMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Style="{StaticResource WinePageRootStyle}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="290"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0" Background="{StaticResource WineAccentBrush}" Margin="18" CornerRadius="24">
			<Grid Padding="18">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Padding="10,18,10,24" Spacing="6">
					<TextBlock Text="Vinoteca" FontSize="30" FontWeight="SemiBold" Foreground="White"/>
					<TextBlock Text="Panel de administracion" Foreground="{StaticResource WineHeroSoftBrush}"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Padding="8,0">
					<Border Background="#1AFFFFFF" CornerRadius="12" Padding="16" Margin="0,0,0,18">
						<StackPanel Spacing="4">
							<TextBlock Text="Control del negocio" Foreground="White" FontWeight="SemiBold"/>
							<TextBlock Text="Gestion de inventario, usuarios y reportes administrativos" TextWrapping="Wrap" Foreground="{StaticResource WineHeroSoftBrush}" FontSize="12"/>
						</StackPanel>
					</Border>

					<Button Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavInventario_Click">
						<Button.Resources>
							<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF"/>
						</Button.Resources>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Library" Foreground="White"/>
							<TextBlock Text="Inventario" VerticalAlignment="Center" Foreground="White"/>
						</StackPanel>
					</Button>

					<Button Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavUsuarios_Click">
						<Button.Resources>
							<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF"/>
						</Button.Resources>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="People" Foreground="White"/>
							<TextBlock Text="Usuarios" VerticalAlignment="Center" Foreground="White"/>
						</StackPanel>
					</Button>

					<Button Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavReportes_Click">
						<Button.Resources>
							<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3AFFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
							<SolidColorBrush x:Key="ButtonForegroundPressed" Color="#FFFFFF"/>
						</Button.Resources>
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Document" Foreground="White"/>
							<TextBlock Text="Reportes" VerticalAlignment="Center" Foreground="White"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<Border Grid.Row="2" Background="#1AFFFFFF" CornerRadius="16" Padding="16">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="10"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<StackPanel Grid.Row="0" Spacing="2">
							<TextBlock x:Name="txtNombreAdminActivo" Text="Admin" FontWeight="SemiBold" Foreground="White"/>
							<TextBlock x:Name="txtCorreoAdminActivo" Text="admin@vinoteca.com" Foreground="{StaticResource WineHeroSoftBrush}" FontSize="12"/>
						</StackPanel>

						<Button Grid.Row="2" x:Name="btnCerrarSesionAdmin" Content="Cerrar sesion" Style="{StaticResource WineSecondaryButtonStyle}" Background="White" Foreground="{StaticResource WineAccentBrush}" BorderBrush="White" Click="btnCerrarSesionAdmin_Click" HorizontalAlignment="Stretch"/>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<Grid Grid.Column="1" Margin="0,18,18,18">
			<Border Style="{StaticResource WineCardStyle}" Padding="0">
				<Frame x:Name="AdminContentFrame"/>
			</Border>
		</Grid>
	</Grid>
</Page>
