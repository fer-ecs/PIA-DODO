<Page
    x:Class="Vinoteca.Views.TiendaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    xmlns:views="using:Vinoteca.Views"
    Background="{StaticResource WineBackgroundBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
		<helpers:ImageSourceConverter x:Key="LocalImageConverter"/>
	</Page.Resources>

	<Grid Background="{StaticResource WineBackgroundBrush}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="360"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Padding="18,8,18,18">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0" Style="{StaticResource WineCardStyle}" Padding="22" Margin="0,0,0,18">
				<Grid RowSpacing="14">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<StackPanel>
							<TextBlock Text="Punto de venta" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
							<TextBlock Text="Busca, filtra y agrega productos al ticket activo." Foreground="{StaticResource WineMutedBrush}" TextWrapping="Wrap"/>
						</StackPanel>
						<Border Grid.Column="1" Background="{StaticResource WineAccentSoftBrush}" CornerRadius="18" Padding="14,8" VerticalAlignment="Center">
							<TextBlock x:Name="txtConteoCatalogo" Text="0 disponibles" Foreground="{StaticResource WineAccentBrush}" FontWeight="SemiBold"/>
						</Border>
					</Grid>

					<Border Grid.Row="1" Grid.RowSpan="2" Style="{StaticResource WineFilterPillStyle}" Padding="12">
						<Grid ColumnSpacing="10" RowSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1.4*"/>
							<ColumnDefinition Width="1*"/>
							<ColumnDefinition Width="1*"/>
							<ColumnDefinition Width="1*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Text="Busqueda" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
						<TextBlock Grid.Column="1" Text="Categoria" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
						<TextBlock Grid.Column="2" Text="Stock" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
						<TextBlock Grid.Column="3" Text="Orden" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>

						<TextBox x:Name="txtBuscar" Grid.Row="1" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Nombre, marca, categoria o ID" MaxLength="50" TextChanged="txtBuscar_TextChanged"/>
						<ComboBox x:Name="cmbFiltroCategoria" Grid.Row="1" Grid.Column="1" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="Filtros_Changed"/>
						<ComboBox x:Name="cmbFiltroStock" Grid.Row="1" Grid.Column="2" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="Filtros_Changed">
							<ComboBoxItem Content="Todo el stock"/>
							<ComboBoxItem Content="Stock bajo"/>
							<ComboBoxItem Content="Mas de 10"/>
						</ComboBox>
						<ComboBox x:Name="cmbOrdenCatalogo" Grid.Row="1" Grid.Column="3" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="Filtros_Changed">
							<ComboBoxItem Content="Nombre A-Z"/>
							<ComboBoxItem Content="Precio menor"/>
							<ComboBoxItem Content="Precio mayor"/>
							<ComboBoxItem Content="Stock menor"/>
							<ComboBoxItem Content="ID"/>
						</ComboBox>
						<Button Grid.Row="1" Grid.Column="4" Content="Limpiar filtros" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnLimpiarFiltros_Click"/>

						<TextBlock Grid.Row="2" Text="Escaner simulado" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
						<TextBox x:Name="txtCodigoEscaneo" Grid.Row="3" Grid.ColumnSpan="4" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="ID corto del producto" MaxLength="12"/>
						<Button Grid.Row="3" Grid.Column="4" Content="Agregar por ID" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnEscanear_Click"/>
					</Grid>
					</Border>

					<TextBlock Grid.Row="3" x:Name="txtEstado" Visibility="Collapsed" TextWrapping="Wrap" Foreground="{StaticResource WineAccentBrush}" FontWeight="SemiBold"/>
				</Grid>
			</Border>

			<GridView x:Name="gvTienda" Grid.Row="1" SelectionMode="None">
				<GridView.ItemTemplate>
					<DataTemplate x:DataType="views:ProductoVentaViewModel">
						<Border Width="210" Margin="6" Style="{StaticResource WineCardStyle}" Padding="10">
							<StackPanel Spacing="8">
								<Border Height="154" CornerRadius="14" Background="{StaticResource WineAccentSoftBrush}" Padding="10">
									<Image Source="{x:Bind ImagenPath, Mode=OneWay, Converter={StaticResource LocalImageConverter}}" MaxHeight="136" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								</Border>
								<TextBlock Text="{x:Bind Nombre}" FontWeight="SemiBold" FontSize="15" TextWrapping="WrapWholeWords" MaxLines="2" Foreground="{StaticResource WineTextBrush}"/>
								<TextBlock Text="{x:Bind Marca}" FontSize="12" Foreground="{StaticResource WineMutedBrush}" TextTrimming="CharacterEllipsis"/>
								<TextBlock Text="{x:Bind Categoria}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind CodigoCorto, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}ID: {0}'}" FontSize="11" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind StockTexto}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind AlertaStockTexto}" Visibility="{x:Bind AlertaStockVisibility}" FontSize="12" Foreground="{StaticResource WineDangerBrush}" FontWeight="SemiBold"/>
								<TextBlock Text="{x:Bind PrecioVenta, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" Foreground="{StaticResource WineHeroBrush}" FontSize="18" FontWeight="Bold"/>
								<Button Content="Agregar a venta" HorizontalAlignment="Stretch" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnAgregar_Click" Tag="{x:Bind Producto}" IsEnabled="{x:Bind PuedeAgregarse}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</GridView.ItemTemplate>
			</GridView>
		</Grid>

		<Border Grid.Column="1" Style="{StaticResource WineCardStyle}" Margin="0,8,18,18" Padding="22">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,12">
					<TextBlock Text="Venta actual" FontWeight="SemiBold" FontSize="22" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Productos listos para cobrar." Foreground="{StaticResource WineMutedBrush}"/>
				</StackPanel>

				<ListView x:Name="lvCarritoRapido" Grid.Row="1" Margin="0,0,0,10" SelectionMode="None">
					<ListView.ItemTemplate>
						<DataTemplate x:DataType="models:CarritoItem">
							<Border Background="{StaticResource WineHeroSoftBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,10">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<StackPanel>
										<TextBlock Text="{x:Bind Producto.Nombre}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
										<TextBlock Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0} unidades'}" FontSize="11" Foreground="{StaticResource WineMutedBrush}"/>
									</StackPanel>

									<TextBlock Grid.Column="1" Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource WineHeroBrush}"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>

				<StackPanel Grid.Row="2" Spacing="10" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
					<TextBlock x:Name="txtCantidadRapida" Text="0 articulo(s)" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
					<Grid>
						<TextBlock Text="Total:" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock x:Name="txtTotalRapido" Text="$0.00" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource WineHeroBrush}"/>
					</Grid>
					<Button Content="Ir a cobro" Click="btnIrAPagar_Click" HorizontalAlignment="Stretch" Style="{StaticResource WinePrimaryButtonStyle}"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Page>
