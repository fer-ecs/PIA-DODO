<Page
    x:Class="Vinoteca.Views.TiendaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
		<helpers:ImageSourceConverter x:Key="LocalImageConverter"/>
	</Page.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="350"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Padding="24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<StackPanel Grid.Row="0" Margin="0,0,0,20">
				<TextBlock Text="Catálogo de Vinos" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>
				<TextBox x:Name="txtBuscar" PlaceholderText="Buscar vino..." Width="300" HorizontalAlignment="Left" TextChanged="txtBuscar_TextChanged"/>
			</StackPanel>

			<GridView x:Name="gvTienda" Grid.Row="1" SelectionMode="None">
				<GridView.ItemTemplate>
					<DataTemplate x:DataType="models:Producto">
						<Grid Width="180" Margin="5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="10" BorderThickness="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
							<StackPanel Spacing="5">
								<Image Source="{x:Bind ImagenPath, Mode=OneWay, Converter={StaticResource LocalImageConverter}}" Height="100" Stretch="UniformToFill"/>
								<TextBlock Text="{x:Bind Nombre}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
								<TextBlock Text="{x:Bind PrecioVenta, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
								<Button Content="+" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Click="btnAgregar_Click" Tag="{x:Bind}"/>
							</StackPanel>
						</Grid>
					</DataTemplate>
				</GridView.ItemTemplate>
			</GridView>
		</Grid>

		<Grid Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="20" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" Text="Resumen de Venta" FontWeight="Bold" FontSize="18" Margin="0,0,0,15"/>

			<ListView x:Name="lvCarritoRapido" Grid.Row="1" Margin="0,0,0,10">
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="models:CarritoItem">
						<Grid Margin="0,5">
							<StackPanel>
								<TextBlock Text="{x:Bind Producto.Nombre}" FontSize="13" FontWeight="SemiBold"/>
								<!-- CORRECCIÓN AQUÍ: Agregado {} para escapar el parámetro -->
								<TextBlock Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0} unidades'}" FontSize="11" Foreground="Gray"/>
							</StackPanel>
							<TextBlock Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13"/>
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>

			<StackPanel Grid.Row="2" Spacing="10" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
				<Grid>
					<TextBlock Text="Total:" FontSize="18" FontWeight="Bold"/>
					<TextBlock x:Name="txtTotalRapido" Text="$0.00" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{ThemeResource SystemControlForegroundAccentBrush}"/>
				</Grid>
				<Button Content="Finalizar y Cobrar" Click="btnIrAPagar_Click" HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}" Padding="0,10"/>
			</StackPanel>
		</Grid>
	</Grid>
</Page>