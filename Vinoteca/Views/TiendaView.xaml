<Page
    x:Class="Vinoteca.Views.TiendaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{StaticResource WineBackgroundBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
		<helpers:ImageSourceConverter x:Key="LocalImageConverter"/>
	</Page.Resources>

	<Grid Background="{StaticResource WineBackgroundBrush}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="360"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Padding="18,8,18,18">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Grid.Row="0" Style="{StaticResource WineCardStyle}" Padding="22" Margin="0,0,0,18">
				<StackPanel Spacing="10">
					<TextBlock Text="Punto de venta" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Busca productos o captura el ID corto para simular un lector de codigo." Foreground="{StaticResource WineMutedBrush}" TextWrapping="Wrap"/>
					<Grid ColumnSpacing="10" RowSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1.3*"/>
							<ColumnDefinition Width="1*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Text="Busqueda" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>
						<TextBlock Grid.Column="1" Text="Escaner simulado" Foreground="{StaticResource WineLabelBrush}" FontWeight="SemiBold"/>

						<TextBox x:Name="txtBuscar" Grid.Row="1" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Nombre, marca, categoria o ID" Foreground="Black" PlaceholderForeground="Black" MaxLength="50" TextChanged="txtBuscar_TextChanged"/>
						<TextBox x:Name="txtCodigoEscaneo" Grid.Row="1" Grid.Column="1" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="ID corto del producto" Foreground="Black" PlaceholderForeground="Black" MaxLength="12"/>
						<Button Grid.Row="1" Grid.Column="2" Content="Agregar por ID" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnEscanear_Click"/>
					</Grid>
					<TextBlock x:Name="txtEstado" Visibility="Collapsed" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>

			<GridView x:Name="gvTienda" Grid.Row="1" SelectionMode="None">
				<GridView.ItemTemplate>
					<DataTemplate x:DataType="models:Producto">
						<Border Width="210" Margin="6" Style="{StaticResource WineCardStyle}" Padding="10">
							<StackPanel Spacing="8">
								<Border CornerRadius="14" Background="{StaticResource WineAccentSoftBrush}" Padding="6">
									<Image Source="{x:Bind ImagenPath, Mode=OneWay, Converter={StaticResource LocalImageConverter}}" Height="132" Stretch="UniformToFill"/>
								</Border>
								<TextBlock Text="{x:Bind Nombre}" FontWeight="SemiBold" FontSize="15" TextWrapping="WrapWholeWords" MaxLines="2" Foreground="{StaticResource WineTextBrush}"/>
								<TextBlock Text="{x:Bind Marca}" FontSize="12" Foreground="{StaticResource WineMutedBrush}" TextTrimming="CharacterEllipsis"/>
								<TextBlock Text="{x:Bind Categoria}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind CodigoCorto, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}ID: {0}'}" FontSize="11" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind Stock, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Stock disponible: {0}'}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
								<TextBlock Text="{x:Bind PrecioVenta, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" Foreground="{StaticResource WineHeroBrush}" FontSize="18" FontWeight="Bold"/>
								<Button Content="Agregar a venta" HorizontalAlignment="Stretch" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnAgregar_Click" Tag="{x:Bind}"/>
							</StackPanel>
						</Border>
					</DataTemplate>
				</GridView.ItemTemplate>
			</GridView>
		</Grid>

		<Border Grid.Column="1" Style="{StaticResource WineCardStyle}" Margin="0,8,18,18" Padding="22">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,12">
					<TextBlock Text="Venta actual" FontWeight="SemiBold" FontSize="22" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Productos listos para cobrar." Foreground="{StaticResource WineMutedBrush}"/>
				</StackPanel>

				<ListView x:Name="lvCarritoRapido" Grid.Row="1" Margin="0,0,0,10" SelectionMode="None">
					<ListView.ItemTemplate>
						<DataTemplate x:DataType="models:CarritoItem">
							<Border Background="{StaticResource WineHeroSoftBrush}" CornerRadius="14" Padding="12" Margin="0,0,0,10">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<StackPanel>
										<TextBlock Text="{x:Bind Producto.Nombre}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
										<TextBlock Text="{x:Bind Cantidad, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0} unidades'}" FontSize="11" Foreground="{StaticResource WineMutedBrush}"/>
									</StackPanel>

									<TextBlock Grid.Column="1" Text="{x:Bind Subtotal, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource WineHeroBrush}"/>
								</Grid>
							</Border>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>

				<StackPanel Grid.Row="2" Spacing="10" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
					<TextBlock x:Name="txtCantidadRapida" Text="0 articulo(s)" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
					<Grid>
						<TextBlock Text="Total:" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock x:Name="txtTotalRapido" Text="$0.00" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource WineHeroBrush}"/>
					</Grid>
					<Button Content="Ir a cobro" Click="btnIrAPagar_Click" HorizontalAlignment="Stretch" Style="{StaticResource WinePrimaryButtonStyle}"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Page>
