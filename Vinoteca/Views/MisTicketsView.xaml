<Page
    x:Class="Vinoteca.Views.MisTicketsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{StaticResource WineBackgroundBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
	</Page.Resources>

	<Grid Background="{StaticResource WineBackgroundBrush}" Padding="12">
		<Border Style="{StaticResource WineCardStyle}" Padding="24">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,20">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel>
							<TextBlock Text="Tickets emitidos" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
							<TextBlock x:Name="txtResumenTickets" Text="Todavia no tienes tickets emitidos" Foreground="{StaticResource WineMutedBrush}"/>
						</StackPanel>

						<Border Grid.Column="1" Padding="16,8" CornerRadius="18" Background="{StaticResource WineAccentSoftBrush}" VerticalAlignment="Top">
							<TextBlock x:Name="txtConteoTickets" Text="0 tickets" Foreground="{StaticResource WineHeroBrush}" FontWeight="SemiBold"/>
						</Border>
					</Grid>

					<Border Style="{StaticResource WineFilterPillStyle}" Padding="16" Margin="0,18,0,0">
						<Grid ColumnSpacing="12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="2*"/>
								<ColumnDefinition Width="220"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<StackPanel>
								<TextBlock Text="Buscar ticket" Style="{StaticResource WineFieldLabelStyle}"/>
								<TextBox x:Name="txtBuscarTicket" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="ID, producto, pago o total" TextChanged="FiltroTickets_Changed" MaxLength="80"/>
							</StackPanel>

							<StackPanel Grid.Column="1">
								<TextBlock Text="Orden" Style="{StaticResource WineFieldLabelStyle}"/>
								<ComboBox x:Name="cmbOrdenTickets" Width="220" Style="{StaticResource WineComboBoxStyle}" SelectionChanged="FiltroTickets_Changed">
									<ComboBoxItem Content="Fecha reciente"/>
									<ComboBoxItem Content="Fecha antigua"/>
									<ComboBoxItem Content="Total mayor"/>
									<ComboBoxItem Content="Total menor"/>
									<ComboBoxItem Content="ID"/>
								</ComboBox>
							</StackPanel>

							<Button Grid.Column="2" Content="Limpiar filtros" Style="{StaticResource WineSecondaryButtonStyle}" VerticalAlignment="Bottom" Click="btnLimpiarTickets_Click"/>
						</Grid>
					</Border>

					<TextBlock x:Name="txtEstado" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
				</StackPanel>

				<Grid Grid.Row="1">
					<ListView x:Name="lvTickets" SelectionMode="None" Background="Transparent">
						<ListView.ItemTemplate>
							<DataTemplate x:DataType="models:Venta">
								<Border Margin="0,0,0,10" Padding="16" CornerRadius="16" Background="#FFF8F2" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1">
									<Grid RowSpacing="10">
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
										</Grid.RowDefinitions>

										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<StackPanel>
												<TextBlock Text="{x:Bind Id, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Ticket: {0}'}" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
												<TextBlock Text="{x:Bind Fecha}" FontSize="12" Foreground="{StaticResource WineMutedBrush}"/>
											</StackPanel>

											<TextBlock Grid.Column="1" Text="{x:Bind Total, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource WineHeroBrush}" VerticalAlignment="Center"/>
										</Grid>

										<Grid Grid.Row="1">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>

											<TextBlock Text="{x:Bind Productos.Count, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0} producto(s) en este ticket'}" Foreground="{StaticResource WineMutedBrush}" VerticalAlignment="Center"/>
											<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
												<Button Content="Previsualizar" Tag="{x:Bind}" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnPrevisualizar_Click"/>
												<Button Content="Descargar PDF" Tag="{x:Bind}" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnDescargarPdf_Click"/>
											</StackPanel>
										</Grid>
									</Grid>
								</Border>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>

					<TextBlock x:Name="txtSinTickets" Text="Aun no hay tickets emitidos" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource WineEmptyStateStyle}"/>
				</Grid>
			</Grid>
		</Border>
	</Grid>
</Page>
