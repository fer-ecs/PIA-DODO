<Page
    x:Class="Vinoteca.Views.InventarioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Background="{StaticResource WineBackgroundBrush}" Padding="24">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="460"/>
			<ColumnDefinition Width="24"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0">
			<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
				<StackPanel Spacing="24">
					<StackPanel Spacing="6">
						<TextBlock Text="Gestion de productos" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock Text="Registra botellas, controla stock y conserva un catalogo claro para la tienda" Foreground="{StaticResource WineMutedBrush}" TextWrapping="Wrap"/>
					</StackPanel>

					<StackPanel Spacing="8">
						<TextBlock Text="Datos principales" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock Text="Nombre del producto" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBox x:Name="txtNombre" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Ej. Casillero del Diablo" MaxLength="60"/>
						<TextBlock Text="Marca" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBox x:Name="txtMarca" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Ej. Concha y Toro" MaxLength="40"/>
					</StackPanel>

					<StackPanel Spacing="8">
						<TextBlock Text="Categoria" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<ComboBox x:Name="cmbCategoria" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch"/>
						<Grid ColumnSpacing="8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBox x:Name="txtNuevaCategoria" Grid.Column="0" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Nueva categoria" MaxLength="30"/>
							<Button x:Name="btnAgregarCategoria" Grid.Column="1" Content="Agregar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnAgregarCategoria_Click"/>
							<Button x:Name="btnEliminarCategoria" Grid.Column="2" Content="Quitar" Style="{StaticResource WineDangerButtonStyle}" Click="btnEliminarCategoria_Click"/>
						</Grid>
					</StackPanel>

					<StackPanel Spacing="8">
						<TextBlock Text="Venta y stock" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<Grid ColumnSpacing="12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<StackPanel Grid.Column="0">
								<TextBlock Text="Precio de venta" Style="{StaticResource WineFieldLabelStyle}"/>
								<TextBox x:Name="txtPrecioVenta" Style="{StaticResource WineTextBoxStyle}" Text="0" MaxLength="9" InputScope="Number"/>
							</StackPanel>
							<StackPanel Grid.Column="1">
								<TextBlock Text="Stock" Style="{StaticResource WineFieldLabelStyle}"/>
								<TextBox x:Name="txtStock" Style="{StaticResource WineTextBoxStyle}" Text="0" MaxLength="4" InputScope="Number"/>
							</StackPanel>
						</Grid>
					</StackPanel>

					<StackPanel Spacing="8">
						<TextBlock Text="Imagen del producto" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<Grid ColumnSpacing="8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBox x:Name="txtImagen" Grid.Column="0" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="Selecciona una imagen local" MaxLength="300" IsReadOnly="True"/>
							<Button x:Name="btnSeleccionarImagen" Grid.Column="1" Content="Seleccionar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnSeleccionarImagen_Click"/>
						</Grid>
					</StackPanel>

					<TextBlock x:Name="txtMensaje" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>

					<Grid ColumnSpacing="8" Margin="0,12,0,24">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Button x:Name="btnGuardar" Grid.Column="0" Content="Guardar" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnGuardar_Click" HorizontalAlignment="Stretch"/>
						<Button x:Name="btnLimpiar" Grid.Column="1" Content="Limpiar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnLimpiar_Click" HorizontalAlignment="Stretch"/>
						<Button x:Name="btnEliminar" Grid.Column="2" Content="Eliminar" Style="{StaticResource WineDangerButtonStyle}" Click="btnEliminar_Click" HorizontalAlignment="Stretch"/>
					</Grid>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<Grid Grid.Column="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<StackPanel Margin="0,0,0,16" Spacing="12">
				<TextBlock Text="Catalogo registrado" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
				<Border Style="{StaticResource WineFilterPillStyle}">
					<Grid ColumnSpacing="10" RowSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="1.2*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="1.4*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Grid.Column="0" Text="Buscar" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="1" Text="Categoria" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="2" Text="Precio min" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="3" Text="Precio max" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="4" Text="Orden" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="5" Text=" " Style="{StaticResource WineFieldLabelStyle}"/>

						<TextBox x:Name="txtBuscar" Grid.Row="1" Grid.Column="0" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="ID, nombre, marca o categoria" MaxLength="50" TextChanged="txtBuscar_TextChanged"/>
						<ComboBox x:Name="cmbFiltroCategoria" Grid.Row="1" Grid.Column="1" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="FiltroProductos_Changed"/>
						<TextBox x:Name="txtPrecioMin" Grid.Row="1" Grid.Column="2" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="0" MaxLength="9" InputScope="Number" TextChanged="FiltroProductos_Changed"/>
						<TextBox x:Name="txtPrecioMax" Grid.Row="1" Grid.Column="3" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="99999" MaxLength="9" InputScope="Number" TextChanged="FiltroProductos_Changed"/>
						<ComboBox x:Name="cmbOrdenProductos" Grid.Row="1" Grid.Column="4" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="FiltroProductos_Changed">
							<ComboBoxItem Content="Nombre A-Z"/>
							<ComboBoxItem Content="Nombre Z-A"/>
							<ComboBoxItem Content="Precio menor"/>
							<ComboBoxItem Content="Precio mayor"/>
							<ComboBoxItem Content="Stock menor"/>
							<ComboBoxItem Content="Stock mayor"/>
							<ComboBoxItem Content="ID"/>
						</ComboBox>
						<Button x:Name="btnLimpiarFiltrosProductos" Grid.Row="1" Grid.Column="5" Content="Limpiar filtros" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnLimpiarFiltrosProductos_Click"/>
					</Grid>
				</Border>
				<TextBlock x:Name="txtResumenProductos" Foreground="{StaticResource WineMutedBrush}" FontSize="13"/>
			</StackPanel>
			<ListView x:Name="lvProductos" Grid.Row="1" SelectionChanged="lvProductos_SelectionChanged" Background="Transparent" BorderThickness="0">
				<ListView.ItemTemplate>
					<DataTemplate>
						<Border Background="#FAFAFA" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="2.4*"/>
									<ColumnDefinition Width="1.2*"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0" VerticalAlignment="Center">
									<TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
									<TextBlock Text="{Binding Marca}" Foreground="{StaticResource WineMutedBrush}" FontSize="12" Margin="0,2,0,0"/>
									<TextBlock Text="{Binding IdTexto}" Foreground="{StaticResource WineLabelBrush}" FontSize="12" Margin="0,2,0,0"/>
								</StackPanel>
								<TextBlock Text="{Binding Categoria}" Grid.Column="1" Foreground="{StaticResource WineMutedBrush}" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding PrecioTexto}" Grid.Column="2" Foreground="{StaticResource WineHeroBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding StockTexto}" Grid.Column="3" Foreground="{StaticResource WineMutedBrush}" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding EstadoTexto}" Grid.Column="4" Foreground="{Binding EstadoBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>
	</Grid>
</Page>
