<Page
    x:Class="Vinoteca.Views.UsuarioMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Style="{StaticResource WinePageRootStyle}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="290"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0" Background="{StaticResource WineAccentBrush}" Margin="18" CornerRadius="24">
			<Grid Padding="18">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Padding="10,18,10,24" Spacing="6">
					<TextBlock Text="Vinoteca" FontSize="30" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Compra y seguimiento" Foreground="#E5D5CC"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Padding="8,0">

					<Button x:Name="btnNavTienda" Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavTienda_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Shop"/>
							<TextBlock Text="Tienda" VerticalAlignment="Center" Foreground="#FFFFFF"/>
						</StackPanel>
					</Button>

					<Button x:Name="btnNavCarrito" Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavCarrito_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<FontIcon Glyph="&#xE7BF;"/>
							<TextBlock Text="Carrito" VerticalAlignment="Center" Foreground="#FFFFFF"/>
							<Border x:Name="bdgCarritoMenu" Background="#FFFFFF" CornerRadius="10" MinWidth="20" Padding="4,0" Visibility="Collapsed">
								<TextBlock x:Name="txtContadorCarritoMenu" Text="0" Foreground="{StaticResource WineAccentBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
							</Border>
						</StackPanel>
					</Button>

					<Button x:Name="btnNavMisTickets" Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavMisTickets_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="Document"/>
							<TextBlock Text="Mis Tickets" VerticalAlignment="Center" Foreground="#FFFFFF"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<Border Grid.Row="2" Background="#5C1720" CornerRadius="18" Padding="16">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="10"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<StackPanel Grid.Row="0" Spacing="2">
							<TextBlock x:Name="txtNombreUsuarioActivo" Text="Usuario" FontWeight="SemiBold" Foreground="#FFFFFF"/>
							<TextBlock x:Name="txtCorreoUsuarioActivo" Text="usuario@vinoteca.com" Foreground="#E5D5CC" FontSize="12"/>
						</StackPanel>

						<Button Grid.Row="2" x:Name="btnCerrarSesionUsuario" Content="Cerrar sesion" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnCerrarSesionUsuario_Click"/>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<Grid Grid.Column="1" Margin="0,18,18,18">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Style="{StaticResource WineCardStyle}" Padding="24" Margin="0,0,0,16">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<StackPanel>
						<TextBlock Text="Tu cava personal" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock Text="Un espacio mas amable para revisar vinos, agregar botellas y consultar tus compras sin distraerte." Foreground="{StaticResource WineMutedBrush}" Margin="0,6,0,0"/>
					</StackPanel>

					<Border Grid.Column="1" Background="{StaticResource WineAccentSoftBrush}" CornerRadius="16" Padding="16,10" VerticalAlignment="Center">
						<TextBlock x:Name="txtRolActivo" Text="Cliente activo" Foreground="{StaticResource WineAccentBrush}" FontWeight="SemiBold"/>
					</Border>
				</Grid>
			</Border>

			<Border Grid.Row="1" Style="{StaticResource WineCardStyle}" Padding="14">
				<Frame x:Name="UsuarioContentFrame"/>
			</Border>
		</Grid>
	</Grid>
</Page>
