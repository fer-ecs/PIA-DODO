<Page
    x:Class="Vinoteca.Views.UsuariosView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Background="{StaticResource WineBackgroundBrush}" Padding="12" ColumnSpacing="20">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="390"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0" Style="{StaticResource WineCardStyle}" Padding="22">
			<StackPanel Spacing="12">
				<TextBlock Text="Gestion de usuarios" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
				<TextBlock x:Name="txtModoFormulario" Text="Nuevo usuario" Foreground="{StaticResource WineHeroBrush}" FontWeight="SemiBold"/>
				<TextBlock Text="Administra cuentas del negocio y clientes registrados desde un mismo panel." TextWrapping="Wrap" Foreground="{StaticResource WineMutedBrush}"/>

				<TextBox x:Name="txtNombre"
                     Style="{StaticResource WineTextBoxStyle}"
                     Header="Nombre"
                     MaxLength="50"
                     PlaceholderText="Nombre del usuario"/>

				<TextBox x:Name="txtCorreo"
                     Style="{StaticResource WineTextBoxStyle}"
                     Header="Correo"
                     MaxLength="80"
                     PlaceholderText="usuario@vinoteca.com"/>

				<PasswordBox x:Name="txtPassword"
                         Style="{StaticResource WinePasswordBoxStyle}"
                         Header="Contrasena"
                         MaxLength="20"
                         PlaceholderText="********"/>

				<PasswordBox x:Name="txtConfirmarPassword"
                         Style="{StaticResource WinePasswordBoxStyle}"
                         Header="Confirmar contrasena"
                         MaxLength="20"
                         PlaceholderText="********"/>

				<CheckBox x:Name="chkEsAdmin" Content="Asignar rol de administrador"/>

				<TextBlock x:Name="txtMensaje"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

				<StackPanel Orientation="Horizontal" Spacing="8">
					<Button x:Name="btnGuardarUsuario" Content="Guardar usuario" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnGuardarUsuario_Click"/>
					<Button x:Name="btnLimpiarUsuario" Content="Limpiar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnLimpiarUsuario_Click"/>
					<Button x:Name="btnEliminarUsuario" Content="Eliminar" Style="{StaticResource WineDangerButtonStyle}" Click="btnEliminarUsuario_Click"/>
				</StackPanel>
			</StackPanel>
		</Border>

		<Border Grid.Column="1" Style="{StaticResource WineCardStyle}" Padding="22">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<StackPanel Margin="0,0,0,12">
					<TextBlock Text="Cuentas registradas" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Selecciona una cuenta para editarla o usa las acciones rapidas de rol y estado." Foreground="{StaticResource WineMutedBrush}" Margin="0,4,0,0"/>
				</StackPanel>

				<ListView x:Name="lvUsuarios" Grid.Row="1" SelectionMode="Single" SelectionChanged="lvUsuarios_SelectionChanged" Background="Transparent">
					<ListView.ItemTemplate>
						<DataTemplate>
							<Border Margin="0,0,0,10" Padding="16" CornerRadius="16" Background="#FFF8F2" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1">
								<Grid ColumnSpacing="12">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<StackPanel>
										<TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
										<TextBlock Text="{Binding Correo}" Foreground="{StaticResource WineMutedBrush}"/>
										<TextBlock Text="{Binding RolTexto}" Foreground="{StaticResource WineMutedBrush}"/>
									</StackPanel>

									<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
										<TextBlock Text="{Binding EstadoTexto}" VerticalAlignment="Center" Foreground="{StaticResource WineMutedBrush}"/>
										<Button Content="{Binding AccionRolTexto}" Style="{StaticResource WineSecondaryButtonStyle}" Tag="{Binding}" Click="btnCambiarRol_Click"/>
										<Button Content="{Binding AccionEstadoTexto}" Style="{StaticResource WineSecondaryButtonStyle}" Tag="{Binding}" Click="btnCambiarEstado_Click"/>
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ListView.ItemTemplate>
				</ListView>
			</Grid>
		</Border>
	</Grid>
</Page>
