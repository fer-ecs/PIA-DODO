<Page
    x:Class="Vinoteca.Views.UsuariosView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Background="{StaticResource WineBackgroundBrush}" Padding="24">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="460"/>
			<ColumnDefinition Width="24"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0">
			<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
				<StackPanel Spacing="24">
					<StackPanel Spacing="6">
						<TextBlock Text="Gestion de usuarios" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock x:Name="txtModoFormulario" Text="Nuevo usuario" Foreground="{StaticResource WineHeroBrush}" FontWeight="SemiBold"/>
						<TextBlock x:Name="txtDescripcionFormulario" Text="Administra cuentas del negocio y empleados registrados desde un mismo panel" TextWrapping="Wrap" Foreground="{StaticResource WineMutedBrush}"/>
					</StackPanel>

					<StackPanel Spacing="4">
						<TextBlock Text="Nombre" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBox x:Name="txtNombre" Style="{StaticResource WineTextBoxStyle}" MaxLength="50" PlaceholderText="Nombre del usuario"/>
					</StackPanel>

					<StackPanel Spacing="4">
						<TextBlock Text="Correo" Style="{StaticResource WineFieldLabelStyle}"/>
						<Grid ColumnSpacing="8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="170"/>
							</Grid.ColumnDefinitions>
							<TextBox x:Name="txtCorreo" Grid.Column="0" Style="{StaticResource WineTextBoxStyle}" MaxLength="40" PlaceholderText="usuario"/>
							<ComboBox x:Name="cmbDominioCorreo" Grid.Column="1" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch"/>
						</Grid>
					</StackPanel>

					<StackPanel Spacing="4">
						<TextBlock Text="Contrasena" Style="{StaticResource WineFieldLabelStyle}"/>
						<PasswordBox x:Name="txtPassword" Style="{StaticResource WinePasswordBoxStyle}" MaxLength="20" PlaceholderText="********"/>
					</StackPanel>

					<StackPanel Spacing="4">
						<TextBlock Text="Confirmar contrasena" Style="{StaticResource WineFieldLabelStyle}"/>
						<PasswordBox x:Name="txtConfirmarPassword" Style="{StaticResource WinePasswordBoxStyle}" MaxLength="20" PlaceholderText="********"/>
					</StackPanel>

					<StackPanel Spacing="4">
						<TextBlock Text="Rol" Style="{StaticResource WineFieldLabelStyle}"/>
						<ComboBox x:Name="cmbRol" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch">
							<ComboBoxItem Content="Administrador"/>
							<ComboBoxItem Content="Supervisor"/>
							<ComboBoxItem Content="Empleado"/>
						</ComboBox>
					</StackPanel>

					<CheckBox x:Name="chkActivo" Content="Cuenta activa" Foreground="{StaticResource WineTextBrush}" Margin="0,-8,0,0"/>

					<TextBlock x:Name="txtMensaje" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>

					<Grid ColumnSpacing="8" Margin="0,8,0,24">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="1.5*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<Button x:Name="btnGuardarUsuario" Grid.Column="0" Content="Guardar" Style="{StaticResource WinePrimaryButtonStyle}" Click="btnGuardarUsuario_Click" HorizontalAlignment="Stretch"/>
						<Button x:Name="btnLimpiarUsuario" Grid.Column="1" Content="Limpiar" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnLimpiarUsuario_Click" HorizontalAlignment="Stretch"/>
						<Button x:Name="btnEliminarUsuario" Grid.Column="2" Content="Eliminar" Style="{StaticResource WineDangerButtonStyle}" Click="btnEliminarUsuario_Click" HorizontalAlignment="Stretch"/>
					</Grid>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<Grid Grid.Column="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<StackPanel Margin="0,0,0,16" Spacing="12">
				<TextBlock Text="Cuentas registradas" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
				<TextBlock x:Name="txtDescripcionLista" Text="Selecciona una cuenta para editarla o revisar su informacion" Foreground="{StaticResource WineMutedBrush}" Margin="0,4,0,0"/>
				<Border Style="{StaticResource WineFilterPillStyle}">
					<Grid ColumnSpacing="10" RowSpacing="8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*"/>
							<ColumnDefinition Width="1.2*"/>
							<ColumnDefinition Width="1.2*"/>
							<ColumnDefinition Width="1.4*"/>
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Grid.Column="0" Text="Buscar" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="1" Text="Rol" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="2" Text="Estado" Style="{StaticResource WineFieldLabelStyle}"/>
						<TextBlock Grid.Column="3" Text="Orden" Style="{StaticResource WineFieldLabelStyle}"/>

						<TextBox x:Name="txtBuscarUsuario" Grid.Row="1" Grid.Column="0" Style="{StaticResource WineTextBoxStyle}" PlaceholderText="ID, nombre o correo" MaxLength="80" TextChanged="FiltroUsuarios_Changed"/>
						<ComboBox x:Name="cmbFiltroRol" Grid.Row="1" Grid.Column="1" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="FiltroUsuarios_Changed">
							<ComboBoxItem Content="Todos"/>
							<ComboBoxItem Content="Administrador"/>
							<ComboBoxItem Content="Supervisor"/>
							<ComboBoxItem Content="Empleado"/>
						</ComboBox>
						<ComboBox x:Name="cmbFiltroEstado" Grid.Row="1" Grid.Column="2" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="FiltroUsuarios_Changed">
							<ComboBoxItem Content="Todos"/>
							<ComboBoxItem Content="Activos"/>
							<ComboBoxItem Content="Inactivos"/>
						</ComboBox>
						<ComboBox x:Name="cmbOrdenUsuarios" Grid.Row="1" Grid.Column="3" Style="{StaticResource WineComboBoxStyle}" HorizontalAlignment="Stretch" SelectionChanged="FiltroUsuarios_Changed">
							<ComboBoxItem Content="Nombre A-Z"/>
							<ComboBoxItem Content="Nombre Z-A"/>
							<ComboBoxItem Content="Rol"/>
							<ComboBoxItem Content="Estado"/>
							<ComboBoxItem Content="ID"/>
						</ComboBox>
					</Grid>
				</Border>
				<TextBlock x:Name="txtResumenUsuarios" Foreground="{StaticResource WineMutedBrush}" FontSize="13"/>
			</StackPanel>
			<ListView x:Name="lvUsuarios" Grid.Row="1" SelectionMode="Single" SelectionChanged="lvUsuarios_SelectionChanged" Background="Transparent" BorderThickness="0">
				<ListView.ItemTemplate>
					<DataTemplate>
						<Border Background="#FAFAFA" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel VerticalAlignment="Center">
									<TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}" FontSize="16"/>
									<TextBlock Text="{Binding Correo}" Foreground="{StaticResource WineMutedBrush}" Margin="0,2,0,0"/>
									<TextBlock Text="{Binding IdTexto}" Foreground="{StaticResource WineLabelBrush}" FontSize="12" Margin="0,2,0,0"/>
									<TextBlock Text="{Binding RolTexto}" Foreground="{StaticResource WineHeroBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
								</StackPanel>
								<StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
									<Border Background="{StaticResource WineAccentSoftBrush}" CornerRadius="6" Padding="12,6">
										<TextBlock Text="{Binding EstadoTexto}" Foreground="{StaticResource WineAccentBrush}" FontWeight="SemiBold" FontSize="12"/>
									</Border>
									<Button Content="{Binding AccionEstadoTexto}" Style="{StaticResource WineSecondaryButtonStyle}" Tag="{Binding}" Click="btnCambiarEstado_Click"/>
								</StackPanel>
							</Grid>
						</Border>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>
	</Grid>
</Page>
