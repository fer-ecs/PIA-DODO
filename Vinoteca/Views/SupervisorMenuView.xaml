<Page
    x:Class="Vinoteca.Views.SupervisorMenuView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource WineBackgroundBrush}">

	<Grid Style="{StaticResource WinePageRootStyle}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="290"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0" Background="{StaticResource WineAccentBrush}" Margin="18" CornerRadius="24">
			<Grid Padding="18">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Padding="10,18,10,24" Spacing="6">
					<TextBlock Text="Vinoteca" FontSize="30" FontWeight="SemiBold" Foreground="#FFFFFF"/>
					<TextBlock Text="Panel de supervision" Foreground="#E5D5CC"/>
				</StackPanel>

				<StackPanel Grid.Row="1" Padding="8,0">

					<Button Style="{StaticResource WineSidebarButtonStyle}" Click="btnNavAnalisis_Click">
						<StackPanel Orientation="Horizontal" Spacing="12">
							<SymbolIcon Symbol="ViewAll"/>
							<TextBlock Text="Analisis de datos" VerticalAlignment="Center" Foreground="#FFFFFF"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<Border Grid.Row="2" Background="#5C1720" CornerRadius="18" Padding="16">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="10"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<StackPanel Grid.Row="0" Spacing="2">
							<TextBlock x:Name="txtNombreSupervisorActivo" Text="Supervisor" FontWeight="SemiBold" Foreground="#FFFFFF"/>
							<TextBlock x:Name="txtCorreoSupervisorActivo" Text="supervisor@vinoteca.com" Foreground="#E5D5CC" FontSize="12"/>
						</StackPanel>

						<Button Grid.Row="2" x:Name="btnCerrarSesionSupervisor" Content="Cerrar sesion" Style="{StaticResource WineSecondaryButtonStyle}" Click="btnCerrarSesionSupervisor_Click"/>
					</Grid>
				</Border>
			</Grid>
		</Border>

		<Grid Grid.Column="1" Margin="0,18,18,18">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Style="{StaticResource WineCardStyle}" Padding="24" Margin="0,0,0,16">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<StackPanel>
						<TextBlock Text="Analisis de datos" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
						<TextBlock Text="Modulo exclusivo para supervision, auditoria y reportes estadisticos." Foreground="{StaticResource WineMutedBrush}" Margin="0,6,0,0"/>
					</StackPanel>

					<Border Grid.Column="1" Background="{StaticResource WineAccentSoftBrush}" CornerRadius="16" Padding="16,10" VerticalAlignment="Center">
						<TextBlock Text="Supervision activa" Foreground="{StaticResource WineAccentBrush}" FontWeight="SemiBold"/>
					</Border>
				</Grid>
			</Border>

			<Border Grid.Row="1" Style="{StaticResource WineCardStyle}" Padding="14">
				<Frame x:Name="SupervisorContentFrame"/>
			</Border>
		</Grid>
	</Grid>
</Page>
