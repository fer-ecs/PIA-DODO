<Page
    x:Class="Vinoteca.Views.ReportesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Vinoteca.Models"
    xmlns:helpers="using:Vinoteca.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Page.Resources>
		<helpers:StringFormatConverter x:Key="LocalStringConverter"/>
	</Page.Resources>

	<Grid Padding="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0,0,0,20">
			<TextBlock Text="Historial de Ventas" Style="{ThemeResource TitleTextBlockStyle}"/>
			<TextBlock x:Name="txtGananciasTotales" Text="Ganancias totales: $0.00" FontSize="18" Foreground="Green" FontWeight="SemiBold"/>
			<TextBlock x:Name="txtResumenVentas" Text="Ventas registradas: 0 | Lineas vendidas: 0" Opacity="0.75"/>
			<TextBlock x:Name="txtEstado" Visibility="Collapsed" Margin="0,8,0,0" TextWrapping="Wrap"/>
		</StackPanel>

		<Grid Grid.Row="1">
			<ListView x:Name="lvHistorialVentas" SelectionMode="None">
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="models:Venta">
						<Grid Padding="15" Margin="0,5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0" VerticalAlignment="Center">
								<TextBlock Text="{x:Bind Fecha}" FontSize="12" Foreground="Gray"/>
								<TextBlock Text="{x:Bind Id, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}Ticket: {0}'}" FontWeight="Bold"/>
							</StackPanel>

							<TextBlock Grid.Column="1" Text="{x:Bind Productos.Count, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0} producto(s) vendidos'}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

							<TextBlock Grid.Column="2" Text="{x:Bind Total, Converter={StaticResource LocalStringConverter}, ConverterParameter='{}{0:C}'}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>

			<TextBlock x:Name="txtSinVentas" Text="Todavia no hay ventas registradas" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}"/>
		</Grid>
	</Grid>
</Page>
