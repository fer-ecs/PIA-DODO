<Page
    x:Class="Vinoteca.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<StackPanel Width="340" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
			<TextBlock Text="Crear Cuenta"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

			<TextBox x:Name="txtNombre"
                     Header="Nombre completo"
                     PlaceholderText="Juan Perez"/>

			<TextBox x:Name="txtCorreo"
                     Header="Correo electronico"
                     PlaceholderText="usuario@vinoteca.com"/>

			<PasswordBox x:Name="txtPassword"
                         Header="Contrasena"
                         PlaceholderText="••••••••"/>

			<PasswordBox x:Name="txtConfirmarPassword"
                         Header="Confirmar contrasena"
                         PlaceholderText="••••••••"/>

			<TextBlock x:Name="txtError"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

			<TextBlock x:Name="txtExito"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

			<Button Content="Crear cuenta"
                    HorizontalAlignment="Stretch"
                    Style="{ThemeResource AccentButtonStyle}"
                    Margin="0,6,0,0"
                    Click="BtnRegistrar_Click"/>

			<Button Content="Volver al login"
                    HorizontalAlignment="Stretch"
                    Click="BtnVolverLogin_Click"/>
		</StackPanel>
	</Grid>
</Page>
