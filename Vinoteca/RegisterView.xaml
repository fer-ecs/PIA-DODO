<Page
    x:Class="Vinoteca.Views.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Background="Transparent">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="5.5*"/>
			<ColumnDefinition Width="4.5*"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Background="{StaticResource WineAccentBrush}" Padding="64">
			<StackPanel VerticalAlignment="Center" MaxWidth="520" Spacing="24">

				<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
					<Border Width="64" Height="64" CornerRadius="8" Background="#5C1824">
						<TextBlock Text="V" Foreground="White" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<TextBlock Text="Vinoteca" FontSize="48" FontWeight="Bold" Foreground="White" CharacterSpacing="-20" VerticalAlignment="Center"/>
				</StackPanel>

				<TextBlock Text="Bienvenido, registrate para poder hacer compras, consultar nuestro inventario y ver tus pedidos." 
                           TextWrapping="WrapWholeWords" FontSize="18" Foreground="#E9D5D5" LineHeight="26"/>

			</StackPanel>
		</Grid>

		<Grid Grid.Column="1" Background="{StaticResource WinePanelBrush}" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1,0,0,0" Padding="64">
			<StackPanel VerticalAlignment="Center" MaxWidth="420" Spacing="24">

				<StackPanel Spacing="6" Margin="0,0,0,8">
					<TextBlock Text="Crear cuenta" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Ingresa tus datos para registrarte en el sistema." Foreground="{StaticResource WineMutedBrush}" FontSize="15"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Nombre completo" Style="{StaticResource WineFieldLabelStyle}"/>
					<TextBox x:Name="txtNombre" Style="{StaticResource WineTextBoxStyle}" MaxLength="50"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Correo electronico" Style="{StaticResource WineFieldLabelStyle}"/>
					<TextBox x:Name="txtCorreo" Style="{StaticResource WineTextBoxStyle}" MaxLength="80"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Contrasena" Style="{StaticResource WineFieldLabelStyle}"/>
					<PasswordBox x:Name="txtPassword" Style="{StaticResource WinePasswordBoxStyle}" MaxLength="20" PasswordRevealMode="Peek" HorizontalAlignment="Stretch"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Confirmar contrasena" Style="{StaticResource WineFieldLabelStyle}"/>
					<PasswordBox x:Name="txtConfirmarPassword" Style="{StaticResource WinePasswordBoxStyle}" MaxLength="20" PasswordRevealMode="Peek" HorizontalAlignment="Stretch"/>
				</StackPanel>

				<TextBlock x:Name="txtError" Foreground="{StaticResource WineDangerBrush}" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>
				<TextBlock x:Name="txtExito" Foreground="{StaticResource WineSuccessBrush}" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>

				<StackPanel Spacing="12" Margin="0,8,0,0">
					<Button Content="Completar registro" Style="{StaticResource WinePrimaryButtonStyle}" Click="BtnRegistrar_Click" HorizontalAlignment="Stretch"/>
					<Button Content="Volver al acceso" Style="{StaticResource WineSecondaryButtonStyle}" Click="BtnVolverLogin_Click" HorizontalAlignment="Stretch"/>
				</StackPanel>

			</StackPanel>
		</Grid>
	</Grid>
</Page>