<Application
    x:Class="Vinoteca.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Vinoteca.Helpers">

	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
			</ResourceDictionary.MergedDictionaries>

			<helpers:StringFormatConverter x:Key="StringFormatConverter"/>

			<SolidColorBrush x:Key="WineBackgroundBrush" Color="Transparent"/>
			<SolidColorBrush x:Key="WinePanelBrush" Color="#FFFFFF"/>
			<SolidColorBrush x:Key="WineSidebarBrush" Color="#F4F4F5"/>

			<SolidColorBrush x:Key="WineTextBrush" Color="#18181B"/>
			<SolidColorBrush x:Key="WineMutedBrush" Color="#71717A"/>
			<SolidColorBrush x:Key="WineLabelBrush" Color="#52525B"/>
			<SolidColorBrush x:Key="WinePlaceholderBrush" Color="#A1A1AA"/>

			<SolidColorBrush x:Key="WineBorderBrush" Color="#E4E4E7"/>
			<SolidColorBrush x:Key="WineAccentBrush" Color="#7A2030"/>
			<SolidColorBrush x:Key="WineHeroBrush" Color="#8F2D3B"/>
			<SolidColorBrush x:Key="WineAccentSoftBrush" Color="#F3E8E8"/>
			<SolidColorBrush x:Key="WineHeroSoftBrush" Color="#E9D5D5"/>

			<SolidColorBrush x:Key="WineDangerBrush" Color="#DC2626"/>
			<SolidColorBrush x:Key="WineSuccessBrush" Color="#16A34A"/>

			<SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FAFAFA"/>
			<SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FAFAFA"/>
			<SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#18181B"/>
			<SolidColorBrush x:Key="TextControlForegroundFocused" Color="#18181B"/>
			<SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#7A2030"/>
			<SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#7A2030"/>

			<SolidColorBrush x:Key="PasswordBoxRevealButtonForeground" Color="Black"/>
			<SolidColorBrush x:Key="PasswordBoxRevealButtonForegroundPointerOver" Color="#7A2030"/>
			<SolidColorBrush x:Key="PasswordBoxRevealButtonForegroundPressed" Color="#18181B"/>
			<SolidColorBrush x:Key="PasswordBoxRevealButtonBackground" Color="Transparent"/>
			<SolidColorBrush x:Key="PasswordBoxRevealButtonBackgroundPointerOver" Color="#F4F4F5"/>

			<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#7A2030"/>
			<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F3E8E8"/>
			<SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#7A2030"/>

			<SolidColorBrush x:Key="AccentButtonBackground" Color="#7A2030"/>
			<SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#8F2D3B"/>
			<SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#5C1824"/>
			<SolidColorBrush x:Key="AccentButtonForeground" Color="#FFFFFF"/>
			<SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FFFFFF"/>
			<SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FFFFFF"/>
			<SolidColorBrush x:Key="AccentButtonBorderBrush" Color="#7A2030"/>
			<SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="#8F2D3B"/>

			<Style x:Key="WinePageRootStyle" TargetType="Grid">
				<Setter Property="Background" Value="{StaticResource WineBackgroundBrush}"/>
			</Style>

			<Style x:Key="WineCardStyle" TargetType="Border">
				<Setter Property="Background" Value="{StaticResource WinePanelBrush}"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineBorderBrush}"/>
				<Setter Property="BorderThickness" Value="1"/>
				<Setter Property="CornerRadius" Value="8"/>
			</Style>

			<Style x:Key="WinePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="20,10"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
				<Setter Property="Background" Value="{StaticResource WineAccentBrush}"/>
				<Setter Property="Foreground" Value="White"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineAccentBrush}"/>
			</Style>

			<Style x:Key="WineSecondaryButtonStyle" TargetType="Button">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="18,9"/>
				<Setter Property="Background" Value="Transparent"/>
				<Setter Property="Foreground" Value="{StaticResource WineAccentBrush}"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineAccentBrush}"/>
				<Setter Property="BorderThickness" Value="1"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
			</Style>

			<Style x:Key="WineDangerButtonStyle" TargetType="Button">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="18,9"/>
				<Setter Property="Background" Value="#FFF0F0"/>
				<Setter Property="Foreground" Value="{StaticResource WineDangerBrush}"/>
				<Setter Property="BorderBrush" Value="#FFD6D6"/>
				<Setter Property="BorderThickness" Value="1"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
			</Style>

			<Style x:Key="WineSidebarButtonStyle" TargetType="Button">
				<Setter Property="HorizontalAlignment" Value="Stretch"/>
				<Setter Property="HorizontalContentAlignment" Value="Left"/>
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Padding" Value="14,10"/>
				<Setter Property="Margin" Value="0,0,0,4"/>
				<Setter Property="Background" Value="Transparent"/>
				<Setter Property="Foreground" Value="White"/>
				<Setter Property="BorderThickness" Value="0"/>
			</Style>

			<Style x:Key="WineTextBoxStyle" TargetType="TextBox">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Background" Value="#FAFAFA"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineBorderBrush}"/>
				<Setter Property="Foreground" Value="Black"/>
			</Style>

			<Style x:Key="WinePasswordBoxStyle" TargetType="PasswordBox">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Background" Value="#FAFAFA"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineBorderBrush}"/>
				<Setter Property="Foreground" Value="Black"/>
				<Setter Property="HorizontalContentAlignment" Value="Left"/>
				<Setter Property="VerticalContentAlignment" Value="Center"/>
				<Setter Property="Padding" Value="12,8"/>
			</Style>

			<Style x:Key="WineComboBoxStyle" TargetType="ComboBox">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Background" Value="#FAFAFA"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineBorderBrush}"/>
				<Setter Property="Foreground" Value="{StaticResource WineTextBrush}"/>
			</Style>

			<Style x:Key="WineNumberBoxStyle" TargetType="NumberBox">
				<Setter Property="CornerRadius" Value="6"/>
				<Setter Property="Background" Value="#FAFAFA"/>
				<Setter Property="BorderBrush" Value="{StaticResource WineBorderBrush}"/>
				<Setter Property="Foreground" Value="{StaticResource WineTextBrush}"/>
			</Style>

			<Style x:Key="WineEmptyStateStyle" TargetType="TextBlock">
				<Setter Property="Foreground" Value="{StaticResource WineLabelBrush}"/>
				<Setter Property="FontSize" Value="20"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
				<Setter Property="TextAlignment" Value="Center"/>
				<Setter Property="Opacity" Value="0.8"/>
			</Style>

			<Style x:Key="WineFieldLabelStyle" TargetType="TextBlock">
				<Setter Property="Foreground" Value="{StaticResource WineLabelBrush}"/>
				<Setter Property="FontSize" Value="12"/>
				<Setter Property="FontWeight" Value="SemiBold"/>
				<Setter Property="Margin" Value="0,8,0,4"/>
			</Style>

		</ResourceDictionary>
	</Application.Resources>
</Application>
