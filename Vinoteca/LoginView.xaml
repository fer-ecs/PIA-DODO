<Page
    x:Class="Vinoteca.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Style="{StaticResource WinePageRootStyle}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="5.5*"/>
			<ColumnDefinition Width="4.5*"/>
		</Grid.ColumnDefinitions>

		<Grid Grid.Column="0" Background="{StaticResource WineAccentBrush}" Padding="64">
			<StackPanel VerticalAlignment="Center" MaxWidth="520" Spacing="24">
				<StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
					<Border Width="64" Height="64" CornerRadius="8" Background="#5C1824">
						<TextBlock Text="V" Foreground="White" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<TextBlock Text="Vinoteca" FontSize="48" FontWeight="Bold" Foreground="White" CharacterSpacing="-20" VerticalAlignment="Center"/>
				</StackPanel>
				<TextBlock Text="Bienvenido al sistema de gestion de inventario y punto de venta. Optimizado para operaciones rapidas y control administrativo." TextWrapping="WrapWholeWords" FontSize="18" Foreground="#E9D5D5" LineHeight="26"/>
			</StackPanel>
		</Grid>

		<Grid Grid.Column="1" Background="{StaticResource WinePanelBrush}" BorderBrush="{StaticResource WineBorderBrush}" BorderThickness="1,0,0,0">
			<StackPanel VerticalAlignment="Center" MaxWidth="380" Spacing="24">

				<StackPanel Spacing="6" Margin="0,0,0,8">
					<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
						<Image Source="Assets/StoreLogo.png" Width="30" Height="30"/>
						<TextBlock Text="Vinoteca" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource WineAccentBrush}" VerticalAlignment="Center"/>
					</StackPanel>
					<TextBlock Text="Iniciar Sesion" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource WineTextBrush}"/>
					<TextBlock Text="Ingresa tus credenciales operativas." Foreground="{StaticResource WineMutedBrush}" FontSize="15"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Correo electronico" Style="{StaticResource WineFieldLabelStyle}"/>
					<TextBox x:Name="txtCorreo" Style="{StaticResource WineTextBoxStyle}" MaxLength="80"/>
				</StackPanel>

				<StackPanel Spacing="4">
					<TextBlock Text="Contraseña" Style="{StaticResource WineFieldLabelStyle}"/>
					<PasswordBox x:Name="txtPassword"
                                 Style="{StaticResource WinePasswordBoxStyle}"
								 Height="36"
                                 MaxLength="20"
                                 PasswordRevealMode="Hidden"
                                 HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Center"/>
				</StackPanel>

				<TextBlock x:Name="txtError" Foreground="{StaticResource WineDangerBrush}" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13" FontWeight="SemiBold"/>

				<StackPanel Spacing="12">
					<Button Content="Ingresar al sistema" Style="{StaticResource WinePrimaryButtonStyle}" Click="BtnLogin_Click" HorizontalAlignment="Stretch"/>
					<Button Content="Solicitar cuenta" Style="{StaticResource WineSecondaryButtonStyle}" Click="BtnIrRegistro_Click" HorizontalAlignment="Stretch"/>
				</StackPanel>

			</StackPanel>
		</Grid>
	</Grid>
</Page>
