<Page
    x:Class="Vinoteca.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

	<Grid>
		<StackPanel Width="320" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
			<TextBlock Text="Inicio de Sesion"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

			<TextBox x:Name="txtCorreo"
                     Header="Correo Electronico"
                     MaxLength="80"
                     PlaceholderText="admin@vinoteca.com"/>

			<PasswordBox x:Name="txtPassword"
                         Header="Contrasena"
                         MaxLength="20"
                         PlaceholderText="••••••••"/>

			<TextBlock x:Name="txtError"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

			<Button Content="Ingresar"
                    HorizontalAlignment="Stretch"
                    Style="{ThemeResource AccentButtonStyle}"
                    Margin="0,8,0,0"
                    Click="BtnLogin_Click"/>

			<TextBlock Text="Las cuentas las crea el administrador"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Opacity="0.75"/>
		</StackPanel>
	</Grid>
</Page>
